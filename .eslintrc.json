{
    "env": {
        "es6": true,
        "node": true
    },
    "extends": ["eslint:recommended", "plugin:jest/recommended"],
    "parserOptions": {
        "ecmaVersion": "latest",
        "sourceType": "module"
    },
    "overrides": [
        {
            "files": ["web-src/**/*.js"],
            "env": {
                "browser": true,
                "es6": true
            },
            "extends": ["plugin:react/recommended"],
            "plugins": ["react"],
            "parserOptions": {
                "ecmaVersion": "latest",
                "sourceType": "module",
                "ecmaFeatures": {
                    "jsx": true
                }
            },
            "settings": {
                "react": {
                    "version": "detect"
                }
            },
            "rules": {
                "react/react-in-jsx-scope": "off",
                "react/prop-types": "off"
            }
        }
    ]
}
